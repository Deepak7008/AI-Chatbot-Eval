# ── API KEYS (secrets — never commit this file) ──────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
LOCAL_API_BASE=http://localhost:11434/v1

# ── OPTIONAL: Defaults when running without the Streamlit UI ──────────────────
# These are only used as fallbacks (e.g., running eval from the command line).
# When using the Streamlit app, the sidebar dropdown overrides these.
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
EVAL_JUDGE_PROVIDER=gemini
EVAL_JUDGE_MODEL=gemini-2.5-flash
